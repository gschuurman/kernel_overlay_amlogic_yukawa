# Extract DTB files from yukawa kernel build outputs
genrule(
    name = "yukawa_dtbs_genrule",
    srcs = ["//common:yukawa"],
    outs = YUKAWA_DTBS,
    cmd = """
        # Copy DTB files from yukawa build outputs
        for src in $(SRCS); do
            case "$$src" in
