# Extract filtered modules for system_dlkm from staging archive
genrule(
    name = "yukawa_system_dlkm_modules_filtered",
    srcs = [":yukawa_system_dlkm_image"],
    outs = ["system_dlkm_filtered.tar"],
    cmd = """
        mkdir -p $(@D)/system_dlkm_filtered
        # Extract staging archive and copy flatten modules
        for f in $(locations :yukawa_system_dlkm_image); do
            if [[ $$f == *staging_archive.tar.gz ]]; then
                tar -xzf $$f -C $(@D)/
                # Copy flatten modules
                if [ -d $(@D)/flatten/lib/modules ]; then
                    cp $(@D)/flatten/lib/modules/*.ko $(@D)/system_dlkm_filtered/ 2>/dev/null || true
                fi
                break
            fi
        done
        tar -cf $@ -C $(@D)/system_dlkm_filtered .
    """,
)

# Extract filtered modules for vendor_dlkm based on modules.load
genrule(
    name = "yukawa_vendor_dlkm_modules_filtered",
    srcs = [
        ":yukawa_vendor_dlkm_image",
        ":yukawa_dist_files",
    ],
    outs = ["vendor_dlkm_filtered.tar"],
    cmd = """
        mkdir -p $(@D)/vendor_dlkm_filtered
        mkdir -p $(@D)/all_modules
        # Copy all modules from common dist (includes Panfrost)
        for f in $(locations :yukawa_dist_files); do
            if [[ $$f == *.ko ]]; then
                cp $$f $(@D)/all_modules/
            fi
        done
        # Find modules.load
        modules_load=""
        for f in $(locations :yukawa_vendor_dlkm_image); do
            if [[ $$f == *modules.load ]] && [[ $$f == *vendor_dlkm* ]]; then
                modules_load=$$f
                break
            fi
        done
        # Copy only filtered modules
        if [ -n "$$modules_load" ]; then
            while IFS= read -r module; do
                [ -z "$$module" ] && continue
                module_name=$$(basename $$module)
                if [ -f $(@D)/all_modules/$$module_name ]; then
                    cp $(@D)/all_modules/$$module_name $(@D)/vendor_dlkm_filtered/
                fi
            done < $$modules_load
        fi
        tar -cf $@ -C $(@D)/vendor_dlkm_filtered .
    """,
)

# # Extract filtered modules for ramdisk based on modules.load
genrule(
    name = "yukawa_ramdisk_modules_filtered",
    srcs = [
        ":yukawa_initramfs",
        ":yukawa_dist_files",
    ],
    outs = ["ramdisk_filtered.tar"],
    cmd = """
        mkdir -p $(@D)/ramdisk_filtered
