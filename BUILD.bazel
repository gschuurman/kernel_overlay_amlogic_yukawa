        for f in $(locations :yukawa_dist_files); do
            if [[ $$f == *.ko ]]; then
                cp $$f $(@D)/all_modules/
            fi
        done
        # Find vendor_boot.modules.load
        modules_load=""
        for f in $(locations :yukawa_initramfs); do
            if [[ $$f == *vendor_boot.modules.load ]]; then
                modules_load=$$f
                break
            fi
        done
        # Copy only filtered modules
        if [ -n "$$modules_load" ]; then
            while IFS= read -r module; do
                [ -z "$$module" ] && continue
