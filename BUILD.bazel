#
# NOTE: Using Image.lz4 in make_goals does not work because
#   kernel build passes legacy option (-l) to lz4 command
#   and u-boot fails to decompress.  Instead, add custom
#   command to lz4 compress same options as kernel, but
#   without the -l.
#
genrule(
    name = "yukawa_kernel_image_lz4",
    srcs = ["//common:kernel_aarch64"],
    outs = ["yukawa-Image.lz4"],
    cmd = """
        # Find the Image file (not Image.gz or Image.lz4)
        IMAGE_FILE=""
        for f in $(locations //common:kernel_aarch64); do
            if [[ $$(basename $$f) == "Image" ]]; then
                IMAGE_FILE=$$f
                break
            fi
        done
        if [ -z "$$IMAGE_FILE" ]; then
            echo "Error: Could not find Image file"
            exit 1
        fi
        lz4 -f -12 --favor-decSpeed $$IMAGE_FILE $@
    """,
)

