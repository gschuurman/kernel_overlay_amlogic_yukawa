                if [ -f $(@D)/all_modules/$$module_name ]; then
                    cp $(@D)/all_modules/$$module_name $(@D)/ramdisk_filtered/
                fi
            done < $$modules_load
        fi
        tar -cf $@ -C $(@D)/ramdisk_filtered .
    """,
)

