                    cp $$src $(location meson-g12b-a311d-khadas-vim3.dtb)
                    ;;
                *meson-sm1-khadas-vim3l.dtb)
                    cp $$src $(location meson-sm1-khadas-vim3l.dtb)
                    ;;
            esac
        done
    """,
)

pkg_files(
    name = "yukawa_dtbs_pkg_files",
