# Flatten all kernel modules for system_dlkm from yukawa_modules_install
genrule(
    name = "yukawa_system_dlkm_modules_flattened",
    srcs = [":yukawa_modules_install"],
    outs = ["system_dlkm_modules_flattened.tar"],
    cmd = """
        mkdir -p $(@D)/system_dlkm_flat
        # Find all .ko files in yukawa_modules_install and copy them flatten
        modules_dir=$$(dirname $(location :yukawa_modules_install))/staging/lib/modules
        if [ -d $$modules_dir ]; then
            find $$modules_dir -name "*.ko" -exec cp {} $(@D)/system_dlkm_flat/ \\; 2>/dev/null || true
            echo "Modules copied: $$(ls $(@D)/system_dlkm_flat/*.ko 2>/dev/null | wc -l)"
        fi
        tar -cf $@ -C $(@D)/system_dlkm_flat .
    """,
)

